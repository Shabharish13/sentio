# Copy this file to `.env` in the same folder and fill in real values.
# `.env` is gitignored — never commit real keys.

# OpenAI — https://platform.openai.com/api-keys  (key starts with sk-proj- or sk-)
# Primary LLM backend when set (flagship model: gpt-5). Needs account billing/credit.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5   # optional override of the default flagship model

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
# Second-choice LLM backend. If neither LLM key works, the agents fall back to the
# logged-in `claude` CLI (Claude Code) automatically.
ANTHROPIC_API_KEY=

# Apollo.io — Settings > Integrations > API  (free tier: ~50 credits/mo)
APOLLO_API_KEY=

# Tavily — https://app.tavily.com  (key starts with tvly-)
TAVILY_API_KEY=

# HubSpot — Service Key (recommended, single-account) OR private app token.
# Service Keys: Settings > Integrations > Service Keys (or Development > Keys > Service Keys).
# Both auth as `Authorization: Bearer <key>`. Needs CRM contacts + deals read/write scopes.
HUBSPOT_TOKEN=

# Non-secret constants (already known; here for the operation cURLs)
HUBSPOT_PIPELINE_ID=default
HUBSPOT_STAGE_DEMO_REQUESTED=3832955632
HUBSPOT_STAGE_DISQUALIFIED=3840698071
